{
  "name": "nodus-panel",
  "version": "1.0.0",
  "description": "Stack server lokal ringan untuk Windows dengan dukungan multi PHP, kontrol layanan, dan otomatisasi virtual host.",
  "license": "ISC",
  "author": "Adi Miuprix",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node dev.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:exe": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.nodus.panel",
    "productName": "Nodus Panel",
    "copyright": "Copyright 2026 Adi Miuprix",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "files": [
      "dist/**/*",
      "src/backend/**/*",
      "usr/**/*",
      "assets/**/*",
      "index.js",
      "package.json"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.13.6",
    "electron-store": "^11.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}